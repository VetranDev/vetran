# Vetran Environment Variables

# JWT secret for signing identity tokens (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here

# Database connection (Railway provides DATABASE_URL automatically when Postgres plugin is added)
DATABASE_URL=postgresql://user:pass@host:port/db

# Node environment
NODE_ENV=production

# Optional: port (Railway sets PORT automatically)
PORT=3000